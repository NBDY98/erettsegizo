# ═══════════════════════════════════════════════════════════════════════════════
# Tracking Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in the values.
# NEXT_PUBLIC_ prefixed variables are exposed to the browser.
# Non-prefixed variables are server-only (never sent to the client).

# ─── Meta (Facebook) ──────────────────────────────────────────────────────────
# Meta Pixel ID — found in Events Manager → Data Sources → Your Pixel
NEXT_PUBLIC_META_PIXEL_ID=

# Meta Conversions API Access Token (SERVER-ONLY — never expose to browser!)
# Generate in: Events Manager → Settings → Conversions API → Generate Access Token
META_ACCESS_TOKEN=

# ─── TikTok ───────────────────────────────────────────────────────────────────
# TikTok Pixel ID — found in TikTok Ads Manager → Assets → Events
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# TikTok Events API Access Token (SERVER-ONLY — never expose to browser!)
# Generate in: TikTok Ads Manager → Assets → Events → Manage → Settings
TIKTOK_ACCESS_TOKEN=

# ─── Existing ─────────────────────────────────────────────────────────────────
REACTBITS_LICENSE_KEY=
